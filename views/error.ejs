<% layout("/layouts/boilerplate.ejs") %>
<style>
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #d8dcee 0%, #764ba2 100%);
      color: #fff;
      /* min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px; */
    }
    
    .container {
      text-align: center;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(10px);
      padding: 3rem 2.5rem;
      border-radius: 16px;
      max-width: 800px;
      width: 100%;
      box-shadow: 0 15px 35px rgba(0,0,0,0.4);
      border: 1px solid rgba(255,255,255,0.15);
    }
    
    .error-code {
      font-size: 8rem;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 1rem;
      text-shadow: 0 10px 20px rgba(0,0,0,0.5);
      background: linear-gradient(90deg, #fff, #ddd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    
    h1 {
      font-size: 2.2rem;
      margin-bottom: 1rem;
      color: #fff;
    }
    
    .message {
      font-size: 1.2rem;
      margin: 1.5rem 0 2.5rem;
      opacity: 0.9;
      line-height: 1.6;
    }
    
    .home-btn {
      display: inline-block;
      padding: 14px 32px;
      background: #fff;
      color: #4a00e0;
      text-decoration: none;
      font-weight: bold;
      border-radius: 50px;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }
    
    .home-btn:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 35px rgba(0,0,0,0.4);
      background: #f0f0ff;
    }
    
    .icon {
      font-size: 5rem;
      margin-bottom: 1.5rem;
      opacity: 0.9;
    }
    
    @media (max-width: 480px) {
      .error-code { font-size: 6rem; }
      h1 { font-size: 1.8rem; }
      .container { padding: 2.5rem 1.8rem; }
    }
  </style>
<div class="container">
      <div class="icon">
        <i class="fas fa-exclamation-triangle fa-beat"></i>
      </div>
      <h1><%= message || "Something went wrong" %></h1>
      <p class="message">
        We're sorry, but an error occurred while processing your request.<br>
        Our team has been notified.
      </p>

    <a href="/listings" class="home-btn">Go Back Home</a>
  </div>