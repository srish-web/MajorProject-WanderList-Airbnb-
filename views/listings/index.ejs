<% layout("/layouts/boilerplate.ejs") %>
<body>
    <h2>All Listings</h2>
    <!-- <form action="/listings/new" method="GET">
        <button>create post</button>
    </form> -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 listing-container">
        <% for(let listing of allListings){ %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="col">
                    <div class="card col listing-card">
                        <div>
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing-img">
                            <div class="card-img-overlay">Guest favourite</div>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <span class="listing-title"><%= listing.title %></span><br>
                                <span class="listing-price">
                                    &#8377; <%= listing.price.toLocaleString("en-IN") %>
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            </a> 
        <% } %>
    </div>
    
</body>