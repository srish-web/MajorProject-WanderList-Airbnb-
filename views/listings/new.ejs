<% layout("/layouts/boilerplate.ejs") %>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h2 class="mb-4">Create a New Listing</h2>
            <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="form-floating mb-3">
                    <input type="text" name="listing[title]" id="title" placeholder="Enter title"
                        class="form-control border-2" required>
                    <label for="title">Enter a catchy title.</label>
                    <div class="invalid-feedback">Please enter a catchy title.</div>
                </div>
                <div class="form-floating mb-3">
                    <textarea name="listing[description]" id="description" placeholder="Enter description"
                        class="form-control border-2" style="height: 100px" required></textarea>
                    <label for="description">Description</label>
                    <div class="invalid-feedback">Please enter a short description.</div>
                </div>
                <!-- <div class="form-floating mb-3">
                    <input type="text" name="listing[image]" id="image" placeholder="Enter URL"
                        class="form-control border-2">
                    <label for="image">Image Link (URL)</label>
                </div> -->
                <div class="form-floating mb-3 p-2">
                    <input type="file" name="listing[image]" id="image"
                        class="form-control border-2" required>
                    <label for="image">Upload Listing image</label>
                </div>
                <div class="row">
                    <div class="form-floating mb-3 col-md-4">
                        <input type="number" name="listing[price]" id="price" placeholder="Price"
                            class="form-control border-2" required>
                        <label for="price" class="ms-2">Price</label>
                        <div class="invalid-feedback">Please enter a valid price.</div>
                    </div>
                    <div class="form-floating mb-3 col-md-8">
                        <input type="text" name="listing[location]" id="location" placeholder="Location"
                            class="form-control border-2" required>
                        <label for="location" class="ms-2">Location</label>
                        <div class="invalid-feedback">Location is required.</div>
                    </div>
                </div>
                <div class="form-floating mb-3">
                    <input type="text" name="listing[country]" id="country" placeholder="Country"
                        class="form-control border-2" required>
                    <label for="country">Country</label>
                    <div class="invalid-feedback">Country name is required.</div>
                </div>
                <button class="btn btn-dark add-btn mt-3 w-100 py-2 shadow transition-button">Add Listing</button>
                <br><br>
            </form>
        </div>
    </div>