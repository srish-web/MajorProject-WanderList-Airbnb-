<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderList</title>
</head>
<body>
    <h2>Create a new listing</h2>
    <form method="post" action="/listings">
        <input type="text" name="listing[title]" placeholder="Enter title">
        <br> <br>
        <textarea name="listing[description]" placeholder="Enter description"></textarea>
        <br> <br>
        <input type="text" name="listing[image]" placeholder="Enter URL/Link">
        <br> <br>
        <input type="number" name="listing[price]" placeholder="Enter price">
        <br> <br>
        <input type="text" name="listing[location]" placeholder="Enter location">
        <br> <br>
        <input type="text" name="listing[country]" placeholder="Enter country name">
        <br> <br>
        <button>Add</button>
        
    </form>
</body>
</html>