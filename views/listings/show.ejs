<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row">
        <div class="col-8 offset-3">
            <h3><b><%= data.title %></b></h3>
        </div>
        <div class="card col-6 offset-3">
            <img src="<%=data.image%>" class="card-img-top show-img" alt="listing-image">
            <div class="card-body">
            <p class="card-text">
                <%= data.description %><br>
                &#8377; <%= data.price.toLocaleString("en-IN") %><br>
                <%= data.location %><br>
                <%= data.country %><br>

            </p>
        </div>
    </div>
    <div class="row">
        <div class="btns">
            <a href="/listings/<%= data._id %>/edit" class="btn btn-dark mb-2 transition-button offset-3">Edit</a>  
            <!-- </div>
            <div class="col-1"> -->
            <form action="/listings/<%= data._id %>?_method=DELETE" method="post">
                <button class="btn btn-dark mb-2 transition-button offset-3">Delete</button>
            </form>
            
        </div>
        <br><hr>
    </div>
    <div class="container">
        <div class="row">
            <div class=" col-md-8  mx-auto">
                <div class="p-4">
                    <h4 class="mb-4 ">Leave a Review</h4>

                    <form action="/listings/<%= data._id %>/reviews" method="POST" novalidate class="needs-validation">
                        
                        <!-- Rating -->
                        <div class="mb-3">
                            <label for="rating" class="form-label">Rating</label>
                            <input 
                                type="range" 
                                class="form-range" 
                                min="1" 
                                max="5" 
                                id="rating" 
                                name="review[rating]"
                            >
                            <div class="d-flex justify-content-between">
                                <small>1</small>
                                <small>5</small>
                            </div>
                        </div>

                        <!-- Comment -->
                        <div class="mb-3">
                            <label for="comment" class="form-label">Comment</label>
                            <textarea 
                                id="comment" 
                                class="form-control" 
                                rows="4" 
                                placeholder="Write your review..."
                                name="review[comment]"
                                required
                            ></textarea>
                            <div class="invalid-feedback">Comment is necessary in review</div>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid">
                            <button class="btn btn-primary">Submit Review</button>
                        </div>

                    </form>
                </div>
                <!-- review ka section -->
                <div class="container mt-4">
                    <h4 class="mb-3 ms-3">All Reviews</h4>                
                </div>
                <div class="row">
                    <% for(let review of data.reviews) { %>
                        <div class="card col-5 col-md-5 ms-5 mb-4 p-2">
                            <div class="d-flex justify-content-between">
                                <h6 class="mb-1 text-dark">
                                    <%= review.rating %> ★
                                </h6>
                                <small class="text-muted">Rating</small>
                            </div>
                            <h4>UserName</h4>
                            <p><%= review.comment %></p>
                            <form action="/lisitngs/<%= data._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                <button class="btn btn-sm btn-dark">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</body>
